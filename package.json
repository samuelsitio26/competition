{
	"name": "monorepo",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"dev": "concurrently --kill-others --raw \"npm run dev --prefix app/web\"",
		"build": "concurrently --raw \"npm run build --prefix app/web\"",
		"deploy": "wrangler pages deploy dist/apps/web",
		"start": "concurrently --kill-others --raw",
		"lint": "concurrently --raw \"npm run lint --prefix app/web\""
	},
	"devDependencies": {
		"concurrently": "^9.1.2",
		"wrangler": "^4.70.0"
	},
	"workspaces": [
		"app/*"
	]
}
